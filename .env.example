# =============================================================================
# Copia este archivo a .env (no se sube a GitHub):
#   copy .env.example .env
#
# Docker (producción local / servidor):
#   docker compose up --build
#   o:  .\scripts\up.ps1
# =============================================================================

# --- API ---
API_PORT=8000
PORT=8000
# Orígenes permitidos para Angular (separados por coma)
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Protección HTTP Basic solo para /docs, /redoc y /openapi.json (opcional).
# Si no defines ambas, la documentación queda abierta (útil en desarrollo local).
# DOCS_USER=admin
# DOCS_PASSWORD=cambia_esta_clave_docs

# --- PostgreSQL (servicio "db" en docker-compose) ---
POSTGRES_USER=panaderia
POSTGRES_PASSWORD=cambia_esta_contraseña
POSTGRES_DB=panaderia
POSTGRES_PORT=5432

# Usada por la API en Docker (host = db). docker-compose también la inyecta.
DATABASE_URL=postgresql+psycopg2://panaderia:cambia_esta_contraseña@db:5432/panaderia

# --- Solo desarrollo SIN Docker (SQLite en archivo local) ---
# DATABASE_URL=sqlite:///./panaderia.db

# --- Supabase (Session pooler — recomendado) ---
# DATABASE_URL=postgresql+psycopg2://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
